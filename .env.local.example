# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.

# --- Public (exposed to the browser) ---
# Found in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---
# Service role key has full DB access. Used only in server modules
# (lib/supabase/admin.ts) and route handlers under /api/admin/*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email of the single account allowed to access /admin.
# Mutations re-check this server-side; RLS policies also gate writes.
ADMIN_EMAIL=you@example.com

# Resend API key for the public contact form. Get one at https://resend.com.
# Free tier: 3000 emails/month, 100/day. Without a verified domain, emails
# are sent from `onboarding@resend.dev` and may land in spam.
RESEND_API_KEY=your-resend-api-key

# Inbox that receives messages submitted via /contact.
CONTACT_TO_EMAIL=you@example.com
